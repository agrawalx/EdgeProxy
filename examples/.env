# Working example `.env` (real deployments would NOT commit this file).
# Demonstrates: overriding listen/log/rps, and leaving EDGEPROXY_CACHE_DIR
# unset so base.yml's ${...:-default} fallback is used instead.

EDGEPROXY_LISTEN=127.0.0.1:8443
EDGEPROXY_LOG_FORMAT=pretty
EDGEPROXY_DEFAULT_RPS=250

API_UPSTREAM_1=http://10.0.0.2:3001
API_UPSTREAM_2=http://10.0.0.3:3001
WEB_UPSTREAM=http://10.0.0.4:8080
