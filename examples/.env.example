# edgeProxy — environment file TEMPLATE
#
# Copy to `.env` in this same directory and edit:
#     cp examples/.env.example examples/.env
#
# Format is plain KEY=value (no `export`, no spaces around `=`).
# `.env` is parsed as a values source only — it does NOT touch your shell env —
# and it takes precedence over the process environment.
#
# NOTE: if you ever store a value containing `$` (e.g. a hashed secret later),
# wrap it in single quotes so it isn't treated as another ${VAR} reference:
#     SOME_SECRET='literal$value'

# Listen address for this host
EDGEPROXY_LISTEN=0.0.0.0:8443

# Log format: json (prod) or pretty (local dev)
EDGEPROXY_LOG_FORMAT=pretty

# Tiered cache: directory for the L2 (RocksDB) store
EDGEPROXY_CACHE_DIR=/var/lib/edgeproxy/cache

# Default per-client rate limit (requests/sec)
EDGEPROXY_DEFAULT_RPS=200

# Upstream pools — per environment
API_UPSTREAM_1=http://10.0.0.2:3001
API_UPSTREAM_2=http://10.0.0.3:3001
WEB_UPSTREAM=http://10.0.0.4:8080
